8/Math/MathML\"><semantics><mrow><mi>γ</mi><mo stretchy=\"false\">(</mo><mn>1</mn><mo stretchy=\"false\">)</mo><mo>=</mo><mn>7</mn></mrow><annotation encoding=\"application/x-tex\">\\gamma(1)=7</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.05556em;\">γ</span><span class=\"mopen\">(</span><span class=\"mord\">1</span><span class=\"mclose\">)</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">7</span></span></span></span>","key":"nOx5v4qQAD"},{"type":"text","value":".","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"hN04IqDxLv"}],"key":"HGA2nVlxph"}],"key":"d3Gz1I2S5w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from tabulate import tabulate\n\nimport numpy as np\n\nfrom mpl_toolkits import mplot3d\nimport matplotlib.colors as mcolors\nimport matplotlib.pyplot as plt\nfrom matplotlib.colors import TABLEAU_COLORS, same_color\n%matplotlib ipympl\n\nR = 3\nr = 1\nw = .4\nh = .4","identifier":"7-torus-prams-code","visibility":"remove","html_id":"id-7-torus-prams-code","key":"mrfBB1JbSW"},{"type":"outputs","id":"9H-imDo515QPKiI3CM-8M","children":[],"identifier":"7-torus-prams-outputs","visibility":"show","html_id":"id-7-torus-prams-outputs","key":"mtBm6g5RsH"}],"data":{"tags":[]},"label":"7-torus-prams","identifier":"7-torus-prams","visibility":"show","html_id":"id-7-torus-prams","key":"SeLS4bblWR"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Below is a pattern and colour chart for a 7-coloured torus, created with the following parameters: R=","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"GKIKwtO6xL"},{"type":"inlineExpression","value":"R","result":{"status":"ok","data":{"text/plain":"3"},"metadata":{}},"children":[{"type":"text","value":"3","key":"KlPrBdBqAP"}],"key":"k0kCnsxo7R"},{"type":"text","value":", r=","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"ePpbC3wz3Z"},{"type":"inlineExpression","value":"r","result":{"status":"ok","data":{"text/plain":"1"},"metadata":{}},"children":[{"type":"text","value":"1","key":"xNZFazFLH1"}],"key":"AKwW8Mf3AJ"},{"type":"text","value":", w=","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"GRNQXOviCK"},{"type":"inlineExpression","value":"w","result":{"status":"ok","data":{"text/plain":"0.4"},"metadata":{}},"children":[{"type":"text","value":"0.4","key":"oWHpn0txSv"}],"key":"uio31Nq4Dq"},{"type":"text","value":", h=","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"iwgsKOdHI8"},{"type":"inlineExpression","value":"h","result":{"status":"ok","data":{"text/plain":"0.4"},"metadata":{}},"children":[{"type":"text","value":"0.4","key":"ij7kzFwJLC"}],"key":"gPPvgsaj5s"},{"type":"text","value":".","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"fF8UoqSyUZ"}],"key":"dd4i3qejYx"}],"key":"VoJTXZbltG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Pattern instructions\nN = round(r * np.pi/h)\nst_count = [0]*(int(N)+1)\npattern = [0]*(int(N)+1)\nrow = [0]*(int(N)+1)\nfor n in range(int(N)+1):\n    st_count[n]=round(2*np.pi*(R-r*np.cos(n*np.pi/int(N)))/w)\n    row[n] = n #\"Row \"+str(n)+\": \"+str(st_count[n])+\" st.\"\n\n# Stitch count table\ntable = np.transpose([row, st_count])\npattern = tabulate(table,headers=[\"Row\",\"Stitch count\"],tablefmt=\"html\")\ndisplay(pattern)\n\n# Pattern model\n\naxs = plt.figure(layout=\"tight\", figsize=(12,12),label=' ').subplot_mosaic(\n    \"\"\"\n    AB\n    CD\n    EE\n    \"\"\",\n    per_subplot_kw={\n        \"ABCD\": {\"projection\": \"3d\"}\n    }\n)\n\n# Set up different viewing directions\naxs[\"A\"].view_init(elev=30, azim=45, roll=0)\naxs[\"B\"].view_init(elev=30, azim=225, roll=0)\naxs[\"C\"].view_init(elev=-30, azim=45, roll=0)\naxs[\"D\"].view_init(elev=-30, azim=225, roll=0)\n\n# Colours\nc = [\n    'gray',\n    'xkcd:bright pink',\n    'xkcd:lime green',\n    'xkcd:yellow',\n    'xkcd:violet',\n    'xkcd:tangerine',\n    'xkcd:kelly green',\n    'xkcd:bright blue'\n]  \n\ncolours = [0]*(N+1)\n\n# UPPER\nfor n in range(int(N)+1):\n    colours[n] = [c[0] for i in range(st_count[n])]\n    for k in range(0,st_count[n]):\n        theta = (n+.5)*np.pi/N\n        phi = (k+.5)*2*np.pi/st_count[n] # slight offset to better reflect crochet stitch distribution\n        \n        m=-(2/3)*N/st_count[n]\n        L1 = m*k+(2/3)*N\n        L2 = m*k+(4/3)*N\n        L3 = m*k+2*N\n        if phi <= np.pi/4:\n            if n<=L1:\n                colours[n][k] = c[1]\n            elif L1<=n<=L2:\n                colours[n][k] = c[2]\n            \n        \n        elif np.pi/4 <= phi <= 3*np.pi/4:\n            \n            if n<=L1:\n                colours[n][k] = c[1]\n            elif L1<=n<=L2:\n                colours[n][k] = c[3]\n            \n    \n        elif 3*np.pi/4 <= phi <= np.pi:\n            \n            if n<=L1:\n                colours[n][k] = c[4]\n            elif L1<=n<=L2:\n                colours[n][k] = c[3]\n            \n           \n        elif np.pi <= phi <= 5*np.pi/4:\n            \n            if n<=L1:\n                colours[n][k] = c[4]\n            elif L1<=n<=L2:\n                colours[n][k] = c[5]\n            elif L2<=n:\n                colours[n][k] = c[6]\n            \n            \n        elif 5*np.pi/4 <= phi <= 3*np.pi/2:\n            \n            if n<=L1:\n                colours[n][k] = c[4]\n            elif L1<=n<=L2:\n                colours[n][k] = c[5]\n            elif L2<=n:\n                colours[n][k] = c[2]\n            \n           \n        elif 3*np.pi/2 <= phi <= 7*np.pi/4:\n            \n            if n<=L1:\n                colours[n][k] = c[7]\n            elif L1<=n<=L2:\n                colours[n][k] = c[5]\n            elif L2<=n:\n                colours[n][k] = c[2]\n            \n           \n        elif 3*np.pi/2 <= phi <= 2*np.pi:\n            \n            if n<=L1:\n                colours[n][k] = c[7]\n            elif L1<=n<=L2:\n                colours[n][k] = c[1]\n            elif L2<=n:\n                colours[n][k] = c[2]\n        \n        u = np.linspace((n-.5)*np.pi/N, (n+.5)*np.pi/N, 2)\n        v = np.linspace((k-.5)*2*np.pi/st_count[n], (k+.5)*2*np.pi/st_count[n], 2)\n        u, v = np.meshgrid(u, v)\n        x = (R-r*np.cos(u))*np.cos(v)\n        y = (R-r*np.cos(u))*np.sin(v)\n        z = r*np.sin(u)\n        \n        # Highlight row 0\n        if n==0:\n            lw=.5\n        else:\n            lw=.1\n        \n        for p in [\"A\",\"B\",\"C\",\"D\"]:\n            axs[p].plot_surface(x, y, z, color=colours[n][k], edgecolor='black', linewidth=lw)\n        axs[\"E\"].scatter(k-st_count[n]/2, n, color=colours[n][k])\n            \n\n# LOWER\nfor n in range(1,int(N)):\n    colours[n] = ['yellow' for i in range(st_count[n])]\n    for k in range(0,st_count[n]):\n        phi = (k+.5)*2*np.pi/st_count[n]\n        \n        m=(2/3)*N/st_count[n]\n        L1 = m*k\n        L2 = m*k+(2/3)*N\n        L3 = m*k+(4/3)*N\n        \n        if phi <= np.pi/4:\n            \n            # n=m*k+(2/3)*N\n            m=(2/3)*N/st_count[n]\n            L1 = m*k\n            L2 = m*k+(2/3)*N\n            L3 = m*k+(4/3)*N\n            if n<=L1:\n                colours[n][k] = c[1]\n            elif L1<=n<=L2:\n                colours[n][k] = c[7]\n            elif L2<=n<=L3:\n                colours[n][k] = c[2]\n            \n    \n        elif np.pi/4 <= phi <= np.pi/2:\n            \n            if n<=L1:\n                colours[n][k] = c[1]\n            elif L1<=n<=L2:\n                colours[n][k] = c[7]\n            elif L2<=n<=L3:\n                colours[n][k] = c[3]\n            \n    \n        elif np.pi/2 <= phi <= 3*np.pi/4:\n            \n            if n<=L1:\n                colours[n][k] = c[1]\n            elif L1<=n<=L2:\n                colours[n][k] = c[6]\n            elif L2<=n<=L3:\n                colours[n][k] = c[3]\n            \n        \n        elif 3*np.pi/4 <= phi <= np.pi:\n            \n            if n<=L1:\n                colours[n][k] = c[4]\n            elif L1<=n<=L2:\n                colours[n][k] = c[6]\n            elif L2<=n<=L3:\n                colours[n][k] = c[3]\n            \n    \n        elif np.pi <= phi <= 5*np.pi/4:\n            \n            if n<=L1:\n                colours[n][k] = c[4]\n            elif L1<=n<=L2:\n                colours[n][k] = c[6]\n            \n    \n        elif 5*np.pi/4 <= phi <= 3*np.pi/2:\n            \n            if n<=L1:\n                colours[n][k] = c[4]\n            elif L1<=n<=L2:\n                colours[n][k] = c[2]\n            \n    \n        elif 3*np.pi/2 <= phi <= 2*np.pi:\n            \n            if n<=L1:\n                colours[n][k] = c[7]\n            elif L1<=n<=L2:\n                colours[n][k] = c[2]\n        \n        u = np.linspace((-n-.5)*np.pi/N, (-n+.5)*np.pi/N, 2)\n        v = np.linspace((k-.5)*2*np.pi/st_count[n], (k+.5)*2*np.pi/st_count[n], 2)\n        u, v = np.meshgrid(u, v)\n        x = (R-r*np.cos(u))*np.cos(v)\n        y = (R-r*np.cos(u))*np.sin(v)\n        z = r*np.sin(u)\n            \n        for p in [\"A\",\"B\",\"C\",\"D\"]:\n            axs[p].plot_surface(x, y, z, color=colours[n][k], edgecolor='black', linewidth=lw)\n        \n        axs[\"E\"].scatter(k-st_count[n]/2, -n, color=colours[n][k])\n        \n# Axis labels for 3d plots\nfor p in [\"A\",\"B\",\"C\",\"D\"]:\n    axs[p].set_xlabel('x')\n    axs[p].set_ylabel('y')\n    axs[p].set_zlabel('z')\n    axs[p].set(zlim=(-R-r,R+r))\n    axs[p].set_aspect('equal')\n\n# Subfigure E is tapestry crochet chart\naxs[\"E\"].set_xlabel('Stitch')\naxs[\"E\"].set_ylabel('Row')\n\nplt.show()","identifier":"7-torus-pattern-code","visibility":"remove","html_id":"id-7-torus-pattern-code","key":"NEDXrfPLkM"},{"type":"outputs","id":"Ixn5nePprKUnysKj-ggH3","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"'<table>\\n<thead>\\n<tr><th style=\"text-align: right;\">  Row</th><th style=\"text-align: right;\">  Stitch count</th></tr>\\n</thead>\\n<tbody>\\n<tr><td style=\"text-align: right;\">    0</td><td style=\"text-align: right;\">            31</td></tr>\\n<tr><td style=\"text-align: right;\">    1</td><td style=\"text-align: right;\">            33</td></tr>\\n<tr><td style=\"text-align: right;\">    2</td><td style=\"text-align: right;\">            36</td></tr>\\n<tr><td style=\"text-align: right;\">    3</td><td style=\"text-align: right;\">            41</td></tr>\\n<tr><td style=\"text-align: right;\">    4</td><td style=\"text-align: right;\">            47</td></tr>\\n<tr><td style=\"text-align: right;\">    5</td><td style=\"text-align: right;\">            53</td></tr>\\n<tr><td style=\"text-align: right;\">    6</td><td style=\"text-align: right;\">            58</td></tr>\\n<tr><td style=\"text-align: right;\">    7</td><td style=\"text-align: right;\">            62</td></tr>\\n<tr><td style=\"text-align: right;\">    8</td><td style=\"text-align: right;\">            63</td></tr>\\n</tbody>\\n</table>'","content_type":"text/plain"},"text/html":{"content":"<table>\n<thead>\n<tr><th style=\"text-align: right;\">  Row</th><th style=\"text-align: right;\">  Stitch count</th></tr>\n</thead>\n<tbody>\n<tr><td style=\"text-align: right