lider.value)}'\nMinorRadiusSlider.observe(update_N_1)\n\ndef update_N_2(m):\n    N.value = f'{round(MinorRadiusSlider.value * np.pi/m[\"owner\"].value)}'\n    init_st_cnt.value = f'{round(2*np.pi*(MajorRadiusSlider.value-MinorRadiusSlider.value)/StitchWidthSlider.value)}'\nStitchHeightSlider.observe(update_N_2)","visibility":"show","key":"Q4oldmE4qI"},{"type":"outputs","id":"rK2j9nmnR_edPUQx9w-ha","children":[],"visibility":"show","key":"rSYwArb2Dh"}],"visibility":"show","key":"zDENvF0npm"},{"type":"block","kind":"notebook-content","data":{"user_expressions":[{"expression":"MajorRadiusText","result":{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"76a02d1bc39141b7bc31ce9b4299dfb2","version_major":2,"version_minor":0},"text/plain":"BoundedFloatText(value=4.0, max=30.0, step=0.01)"},"metadata":{},"status":"ok"}},{"expression":"MinorRadiusText","result":{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"52d3053b121848caac6566ca04b87e85","version_major":2,"version_minor":0},"text/plain":"BoundedFloatText(value=1.78, max=30.0, step=0.01)"},"metadata":{},"status":"ok"}},{"expression":"StitchWidthText","result":{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"4fc582657329478ba3f8b73424a56b24","version_major":2,"version_minor":0},"text/plain":"BoundedFloatText(value=0.4, max=5.0, step=0.01)"},"metadata":{},"status":"ok"}},{"expression":"StitchHeightText","result":{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"da9df9398a58494b921b86e47c6cf364","version_major":2,"version_minor":0},"text/plain":"BoundedFloatText(value=0.4, max=5.0, step=0.01)"},"metadata":{},"status":"ok"}},{"expression":"N","result":{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"59cc7a86a0904dd2bb455d0ea31b0966","version_major":2,"version_minor":0},"text/plain":"Label(value='14')"},"metadata":{},"status":"ok"}},{"expression":"N","result":{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"59cc7a86a0904dd2bb455d0ea31