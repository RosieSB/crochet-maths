t(N)))/w)\n            #if n<10:\n            #    print('  Row  ',n,': ',st_count[n],' st')\n            #else:\n            #    print('  Row ',n,': ',st_count[n],' st')\n            pattern[n] = widgets.HBox([widgets.ToggleButton(value=False,description=\"Row \"+str(n)+\": \"+str(st_count[n])+\" st\",indent=True)])\n    display(widgets.VBox(pattern))\n\nout = widgets.interactive_output(f, {'R': R, 'r': r, 'w': w, 'h': h})\n\n\npattern_layout = Layout(display='flex',\n                    flex_flow='column wrap', \n                    align_items='center', \n                    border='solid')\n\nwidgets.HBox(\n    [\n    widgets.VBox([widgets.HTML(value=\"<center><b>Choose pattern dimensions (cm):\"), R, r, w, h]),\n    widgets.VBox([widgets.HTML(value=\"<center><b>Stitch count per row:\"),out])#,layout=pattern_layout)\n    ],\n    layout=Layout(display='flex',align_items='center',justify_content='space-around',width='80%')\n)","identifier":"interactive-torus-code","visibility":"remove","html_id":"interactive-torus-code","key":"A2Qo9sXUx9"},{"type":"outputs","id":"DAgnYj2S3jSQkiRUjcbGm","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"VBox(children=(HBox(children=(ToggleButton(value=False, description='Row 0: 35 st'),)), HBox(children=(ToggleB…","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"2427bdf7a1e943099fc1c53003fd8e0f\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"identifier":"interactive-torus-outputs-0","html_id":"interactive-torus-outputs-0","key":"dIn2PIo5o1"},{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"text/plain":{"content":"HBox(children=(VBox(children=(HTML(value='<center><b>Choose pattern dimensions (cm):'), FloatText(value=4.0, d…","content_type":"text/plain"},"application/vnd.j