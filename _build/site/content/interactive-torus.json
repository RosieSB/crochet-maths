          print('  Row ',n,': ',st_count[n],' st')\n\nout = widgets.interactive_output(f, {'R': R, 'r': r, 'w': w, 'h': h})\n\nwidgets.VBox([widgets.HTML(value=\"Choose pattern parameters:\"),\n              widgets.GridBox([R,r,w,h],),\n              out])","identifier":"interactive-torus-code","visibility":"remove","html_id":"interactive-torus-code","key":"hnaGaRfZaG"},{"type":"outputs","id":"MsxR1UuKdUu2y8aa-Kqg9","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Stitch count per row:\n---------------------\n  Row   0 :  35  st\n  Row   1 :  36  st\n  Row   2 :  38  st\n  Row   3 :  41  st\n  Row   4 :  45  st\n  Row   5 :  51  st\n  Row   6 :  57  st\n  Row   7 :  63  st\n  Row   8 :  69  st\n  Row   9 :  75  st\n  Row  10 :  80  st\n  Row  11 :  85  st\n  Row  12 :  88  st\n  Row  13 :  90  st\n  Row  14 :  91  st\n"},"identifier":"interactive-torus-outputs-0","html_id":"interactive-torus-outputs-0","key":"nJgmc6ymfJ"},{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"text/plain":{"content":"VBox(children=(HTML(value='Choose pattern parameters:'), GridBox(children=(FloatText(value=4.0, description='M…","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"ccbc6c70d4d94884ad54556eccf20bfd\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"identifier":"interactive-torus-outputs-1","html_id":"interactive-torus-outputs-1","key":"CHHsQCB8Lj"}],"identifier":"interactive-torus-outputs","visibility":"show","html_id":"interactive-torus-outputs","key":"rjcXLOe71W"}],"data":{"tags":[]},"label":"interactive-torus","identifier":"interactive-torus","visibility":"show","html_id":"interactive-torus","key":"aSEgakYsjK"}],"key":"QlQq3xMlr1"},"references":{"cite":{"order":[],"data":{}}}}