"line":14,"column":1}},"children":[{"type":"strong","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Upper half:","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"AwQQ5aCusb"}],"key":"pSS9HJHeFt"},{"type":"text","value":" Begin with a foundation chain joined into a loop. Work the following stitch counts in each row. Increases are made using 2 st in st of previous row, evenly distributed for a symmetrical look.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"DnAGA6ZfTQ"}],"key":"lrKHoHxkIz"}],"key":"T5WqxEOHKW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import ipywidgets as widgets\nfrom ipywidgets import Layout\nimport numpy as np\n\nR = widgets.FloatText(value=4,min=0,max=30,step=.01,description='Major radius')\nr = widgets.FloatText(value=1.78,min=0,max=30,step=.01,description='Minor radius')\nw = widgets.FloatText(value=.4,min=0,max=5,step=.01,description='Stitch width')\nh = widgets.FloatText(value=.4,min=0,max=5,step=.01,description='Stitch height')\n\n\ndef f(R,r,w,h):\n    print('Stitch count per row:\\n---------------------')\n    N = round(r * np.pi/h)\n    st_count = [0]*(int(N)+1)\n    for n in range(int(N)+1):\n        st_count[n]=round(2*np.pi*(R-r*np.cos(n*np.pi/int(N)))/w)\n        if n<10:\n            print('  Row  ',n,': ',st_count[n],' st')\n        else:\n            print('  Row ',n,': ',st_count[n],' st')\n\nout = widgets.interactive_output(f, {'R': R, 'r': r, 'w': w, 'h': h})\n\nwidgets.VBox([widgets.HTML(value=\"Choose pattern parameters:\"),\n              widgets.GridBox([R,r,w,h],),\n              out])","identifier":"interactive-torus-code","visibility":"remove","html_id":"interactive-torus-code","key":"gGMnPgPylb"},{"type":"outputs","id":"f9VAwytrArbjnQjc9TEn6","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Stitch count per row:\n---------------------\n  Row   0 :  35  st\n  Row   1 :  36  st\n  Row   2 :  38  st\n  Row   3 :  41  st\n  Row   4 :  45  st\n  Row   5 :  51  st\n  Row   6 :  57  st\n  Row   7 :  63  st\n  Row   8 :  69  st\n  Row   9 :  75  st\n  Row  10 :  80  st\n  Row  11 :  85  st\n  Row  12 :  88  st\n  Row  13 :  90  st\n  Row  14 :  91  st\n"},"identifier":"interactive-torus-outputs-0","html_id":"interactive-torus-outputs-0","key":"XenebU8305"},{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"text/plain":{"content":"VBox(children=(HTML(value='Choose pattern parameters:'), GridBox(children=(FloatText(value=4.0, description='M…","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"ccbc6c70d4d94884ad54556eccf20bfd\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"identifier":"interactive-torus-outputs-1","html_id":"interactive-torus-outputs-1","key":"NceeIUuiFw"}],"identifier":"interactive-torus-outputs","visibility":"show","html_id":"interactive-torus-outputs","key":"E9a1pccrAE"}],"data":{"tags":[]},"label":"interactive-torus","identifier":"interactive-torus","visibility":"show","html_id":"interactive-torus","key":"RNMiot8pNW"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"strong","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Lower half:","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"rHAjzuZEOJ"}],"key":"tLp34Ra9uP"},{"type":"text","value":" Same as upper half, but with first and last rows omitted.","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"WPkBI9IU4R"}],"key":"EeSlWfGI5k"},{"type":"paragraph","position":{"start":{"line":49,"column":1},